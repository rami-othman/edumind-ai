APP_NAME=EduMind AI Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=edumind_content
CHROMA_DISTANCE_FUNCTION=cosine

# ollama configuration
OLLAMA_API_KEY=your_real_ollama_api_key_here
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=deepseek-v4-pro:cloud
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=

# Future placeholder only, not implemented yet
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2
GOOGLE_EMBEDDING_DIMENSION=768

UPLOAD_DIR=/app/data/uploads
PROCESSED_DIR=/app/data/processed

CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
